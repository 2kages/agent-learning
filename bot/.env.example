# Slack app credentials (Socket Mode — no public URL needed)
SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...

# Comma-separated Slack user IDs allowed to talk to the bot
ALLOWED_USER_IDS=U01ABCDEF,U02GHIJKL

# Default worktree to use when @mention does not specify one.
# Point this at a Conductor worktree to share sessions with the desktop UI.
DEFAULT_WORKTREE=/Users/you/ConductorWorkspaces/my-repo

# Optional: path to the `claude` CLI. Leave unset to use $PATH.
# CLAUDE_BIN=/opt/homebrew/bin/claude
